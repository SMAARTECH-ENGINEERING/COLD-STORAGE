# ============================================================
# COLD STORAGE MONITORING SYSTEM - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and update values before running

# ---- Server ----
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017/cold_storage_db
MONGODB_URI_PROD=mongodb+srv://<user>:<pass>@cluster.mongodb.net/cold_storage_db

# ---- JWT ----
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_change_in_prod
JWT_REFRESH_EXPIRES_IN=7d

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Sensor Alert Thresholds ----
DOOR_OPEN_ALERT_MINUTES=5
DEVICE_OFFLINE_MINUTES=10

# ---- Logging ----
LOG_LEVEL=info
LOG_DIR=./logs

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Seed Admin ----
SEED_ADMIN_EMAIL=superadmin@coldstorage.com
SEED_ADMIN_PASSWORD=Admin@1234
